    n1[/"profile-audience3<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("PROFILE.MEMBERS")]
  n3[("PROFILE.AUDIENCE3")]
  n2 --> n1
  n1 --> n3
!graph PROFILE.AUDIENCE3


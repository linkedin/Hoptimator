!set outputformat mysql
!use k8s

# ─────────────────────────────────────────────────────────────────────────────
# Test 1: reverse lookup against an identifier whose schema doesn't exist in this
# connection. Surfaces as an error rather than a degenerate graph — the resolver
# walks the path through Calcite's schema tree and "UNKNOWN" isn't a sub-schema.
# ─────────────────────────────────────────────────────────────────────────────

Error: Identifier UNKNOWN.FOO does not exist: schema segment 'UNKNOWN' not found in this connection.
!graph UNKNOWN.FOO

# ─────────────────────────────────────────────────────────────────────────────
# Test 2: known schema, unknown table. PROFILE resolves to a Database in the
# catalog, but does-not-exist isn't a Table — surfaces as an error rather than
# an empty graph + warning. (The no-pipelines warning is reserved for tables
# that exist but happen to have no referencing pipelines.)
# ─────────────────────────────────────────────────────────────────────────────

Error: Identifier PROFILE.does-not-exist does not exist: table 'does-not-exist' not found in schema PROFILE.
!graph PROFILE.does-not-exist

# ─────────────────────────────────────────────────────────────────────────────
# Test 3: partial materialized view
# ─────────────────────────────────────────────────────────────────────────────

create or replace materialized view PROFILE."COMPANIES$graph-test" as select COMPANY_URN as COMPANY_URN, MEMBER_URN as COMPANY_NAME from PROFILE.MEMBERS;
(0 rows modified)

!update

flowchart LR
  subgraph n0["Materialized View"]
    n1[/"profile-companies-graph-test<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("PROFILE.MEMBERS")]
  n3[("PROFILE.COMPANIES")]
  n2 --> n1
  n1 --> n3
!graph PROFILE.COMPANIES$graph-test

flowchart LR
  n0[("PROFILE.MEMBERS")]
  n1[/"profile-companies-graph-test<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("PROFILE.COMPANIES")]
  n0 --> n1
  n1 --> n2
!graph PROFILE.MEMBERS

flowchart LR
  n0[("PROFILE.COMPANIES")]
  n1[/"profile-companies-graph-test<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("PROFILE.MEMBERS")]
  n2 --> n1
  n1 --> n0
!graph PROFILE.COMPANIES

# ─────────────────────────────────────────────────────────────────────────────
# Test 4: materialized view w/ join
# Also tests combined graph with multiple views from the test above
# ─────────────────────────────────────────────────────────────────────────────

create or replace materialized view PROFILE.MULTI as select first_name, last_name from PROFILE.COMPANIES natural join PROFILE.MEMBERS;
(0 rows modified)

!update

flowchart LR
  subgraph n0["Materialized View"]

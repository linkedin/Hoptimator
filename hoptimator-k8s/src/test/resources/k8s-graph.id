  n2[("PROFILE.COMPANIES")]
  n3[/"profile-multi<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n4[("PROFILE.MULTI")]
  n0 --> n1
  n1 --> n2
  n2 --> n3
  n0 --> n3
  n3 --> n4
!graph PROFILE.MEMBERS

flowchart LR
  n0[("PROFILE.COMPANIES")]
  n1[/"profile-companies-graph-test<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("PROFILE.MEMBERS")]
  n3[/"profile-multi<br/>kind: FlinkSessionJob<br/>engine: Flink"/]

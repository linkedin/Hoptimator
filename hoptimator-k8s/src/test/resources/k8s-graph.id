  n1 --> n0
  n0 --> n3
  n2 --> n3
  n3 --> n4
!graph PROFILE.COMPANIES

# ─────────────────────────────────────────────────────────────────────────────
# Test 5: Depth checks
# ─────────────────────────────────────────────────────────────────────────────

# No expected change because depth 1 is bidirectional from source and sink
flowchart LR
  n0[("PROFILE.COMPANIES")]
  n1[/"profile-companies-graph-test<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("PROFILE.MEMBERS")]
  n3[/"profile-multi<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n4[("PROFILE.MULTI")]
  n2 --> n1
  n1 --> n0
  n0 --> n3
  n2 --> n3
  n3 --> n4
!graph PROFILE.COMPANIES --depth 1

flowchart LR
  n0[("PROFILE.COMPANIES")]
!graph PROFILE.COMPANIES --depth 0

flowchart LR
  subgraph n0["Materialized View"]
    n1[/"profile-multi<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("PROFILE.COMPANIES")]
  n3[("PROFILE.MEMBERS")]
  n4[("PROFILE.MULTI")]
  n2 --> n1
  n3 --> n1
  n1 --> n4
!graph PROFILE.MULTI --depth 1

drop materialized view PROFILE.MULTI;
(0 rows modified)

!update

drop materialized view PROFILE."COMPANIES$graph-test";
(0 rows modified)

!update

# ─────────────────────────────────────────────────────────────────────────────
# Test 6: MV-on-MV inlining produces fan-out from the physical source.
# AUDIENCE2 and AUDIENCE3 are defined to read from AUDIENCE, but Calcite
# inlines AUDIENCE's body so the resulting pipelines all read directly
# from PROFILE.MEMBERS. The graph reflects operational truth (post-inline),
# not user intent, so `!graph PROFILE.MEMBERS` fans out to 3 pipelines.
# ─────────────────────────────────────────────────────────────────────────────

create or replace materialized view PROFILE.AUDIENCE as select COMPANY_URN as COMPANY_URN, MEMBER_URN as COMPANY_NAME from PROFILE.MEMBERS;
(0 rows modified)

!update

create or replace materialized view PROFILE.AUDIENCE2 as select COMPANY_URN from PROFILE.AUDIENCE;
(0 rows modified)

!update

create or replace materialized view PROFILE.AUDIENCE3 as select COMPANY_URN from PROFILE.AUDIENCE;
(0 rows modified)

!update


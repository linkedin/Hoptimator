# ─────────────────────────────────────────────────────────────────────────────
# Test 6: MV-on-MV inlining produces fan-out from the physical source.
# AUDIENCE2 and AUDIENCE3 are defined to read from AUDIENCE, but Calcite
# inlines AUDIENCE's body so the resulting pipelines all read directly
# from ADS.AD_CLICKS. The graph reflects operational truth (post-inline),
# not user intent, so `!graph table ADS.AD_CLICKS` fans out to 3 pipelines.
# ─────────────────────────────────────────────────────────────────────────────

create or replace materialized view ADS.AUDIENCE as select MEMBER_URN as MEMBER_URN, CAMPAIGN_URN as PAGE_URN from ADS.AD_CLICKS;
(0 rows modified)

!update

create or replace materialized view ADS.AUDIENCE2 as select PAGE_URN from ADS.AUDIENCE;
(0 rows modified)

!update

create or replace materialized view ADS.AUDIENCE3 as select PAGE_URN from ADS.AUDIENCE;
(0 rows modified)

!update

flowchart LR
  subgraph n0["Materialized View"]
    n1[/"ads-audience2<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("ADS.AD_CLICKS")]
  n3[("ADS.AUDIENCE2")]
  n2 --> n1
  n1 --> n3
!graph view ADS.AUDIENCE2

flowchart LR
  subgraph n0["Materialized View"]
    n1[/"ads-audience3<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("ADS.AD_CLICKS")]
  n3[("ADS.AUDIENCE3")]
  n2 --> n1
  n1 --> n3
!graph view ADS.AUDIENCE3

flowchart LR
  subgraph n0["Materialized View"]
    n1[/"ads-audience<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2[("ADS.AD_CLICKS")]
  n3[("ADS.AUDIENCE")]
  n2 --> n1
  n1 --> n3
!graph view ADS.AUDIENCE

flowchart LR
  n0[("ADS.AD_CLICKS")]
  n1[/"ads-audience<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("ADS.AUDIENCE")]
  n3[/"ads-audience2<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n4[("ADS.AUDIENCE2")]
  n5[/"ads-audience3<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n6[("ADS.AUDIENCE3")]
  n0 --> n1
  n1 --> n2
  n0 --> n3
  n3 --> n4
  n0 --> n5
  n5 --> n6
!graph table ADS.AD_CLICKS

drop materialized view ADS.AUDIENCE3;
(0 rows modified)

!update


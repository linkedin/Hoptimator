!set outputformat mysql
!use k8s

# Register a VARCHAR UDF (default return type)
create function my_udf as 'com.example.MyUdf';
(0 rows modified)

!update

# UDF validates against real data
select my_udf("FIRST_NAME") as val from profile.members;
+-----+
| VAL |
+-----+
|     |
|     |
|     |

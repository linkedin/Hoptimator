!set outputformat mysql
!use k8s

# Integration tests for logical table DDL.
#
# Prerequisites (handled by test infrastructure):
#   kubectl apply -f deploy/logicaltables.crd.yaml
#   kubectl apply -f deploy/samples/logicaldb.yaml       (defines LOGICAL schema)
#   kubectl apply -f deploy/samples/kafkadb.yaml         (defines kafka-database / KAFKA schema)
#   kubectl apply -f deploy/samples/venicedb.yaml        (defines venice / VENICE schema)
#   Kafka + Venice running (see deploy/dev/ and deploy/docker/venice/)

# ─────────────────────────────────────────────────────────────────────────────
# Test 1: CREATE TABLE — basic two-column logical table
# ─────────────────────────────────────────────────────────────────────────────
create table "LOGICAL"."testevent" ("memberId" bigint, "pageKey" varchar);
(0 rows modified)

!update

# ─────────────────────────────────────────────────────────────────────────────
# Test 2: !describe — columns resolved from nearline physical tier schema
# ─────────────────────────────────────────────────────────────────────────────

+------------+----------+------------+------------+
| columnName | typeName | columnSize | isNullable |
+------------+----------+------------+------------+
| memberId   | BIGINT   | 19         | YES        |
| pageKey    | VARCHAR  | null       | YES        |
+------------+----------+------------+------------+
(2 rows)

!describe "LOGICAL"."testevent"

# ─────────────────────────────────────────────────────────────────────────────
# Test 3: Pipeline CRD created for nearline→online sync
# ─────────────────────────────────────────────────────────────────────────────
select name from "k8s".pipelines where name = 'logical-testevent-nearline-to-online';
+--------------------------------------+
| NAME                                 |
+--------------------------------------+
| logical-testevent-nearline-to-online |
+--------------------------------------+
(1 row)

!ok

# ─────────────────────────────────────────────────────────────────────────────
# Test 4: CREATE TABLE with nested ROW types
# ─────────────────────────────────────────────────────────────────────────────
create table "LOGICAL"."pageview" (
  "header" row("memberId" bigint, "timestamp" bigint),
  "body" row("pageKey" varchar, "tags" varchar array)
);
(0 rows modified)

!update

+------------+----------+------------+------------+
| columnName | typeName | columnSize | isNullable |
+------------+----------+------------+------------+
| header     | RECORD   | null       | YES        |
| body       | RECORD   | null       | YES        |
+------------+----------+------------+------------+
(2 rows)

!describe "LOGICAL"."pageview"

# ─────────────────────────────────────────────────────────────────────────────
# Test 5: CREATE OR REPLACE TABLE — update schema (add a column)
# Each physical tier deployer validates backward compatibility.
# ─────────────────────────────────────────────────────────────────────────────
create or replace table "LOGICAL"."testevent" (
  "memberId" bigint,
  "pageKey" varchar,
  "sessionId" varchar
);
(0 rows modified)

!update

# After update, the pipeline SQL should reference the new schema.
# The pipeline name should remain the same (idempotent update).
select count(*) from "k8s".pipelines where name = 'logical-testevent-nearline-to-online';
+--------+
| EXPR$0 |
+--------+
|      1 |
+--------+
(1 row)

!ok

# ─────────────────────────────────────────────────────────────────────────────
# Test 6: DROP TABLE — disabled; should fail with helpful error message
# ─────────────────────────────────────────────────────────────────────────────
drop table "LOGICAL"."testevent";
Logical table deletion is not yet supported
!error

# ─────────────────────────────────────────────────────────────────────────────
# Test 7: CREATE TABLE against non-existent schema is rejected
# ─────────────────────────────────────────────────────────────────────────────
create table "LOGICAL-NONEXISTENT"."testevent" ("id" bigint);
Schema for LOGICAL-NONEXISTENT.TESTEVENT not found.
!error

# ─────────────────────────────────────────────────────────────────────────────
# Clean up
# ─────────────────────────────────────────────────────────────────────────────
drop table "LOGICAL"."pageview";
(0 rows modified)

!update

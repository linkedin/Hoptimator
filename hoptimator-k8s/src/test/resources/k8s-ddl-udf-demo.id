!set outputformat mysql
!use k8s

# Register demo Java UDFs baked into the Flink runner image
create function greet as 'com.linkedin.hoptimator.flink.runner.functions.Greet';
(0 rows modified)

!update

create function str_len returns integer as 'com.linkedin.hoptimator.flink.runner.functions.StringLength';
(0 rows modified)

!update

# Register demo Python UDF baked into the Flink runner image
create function reverse_str language python as 'reverse_string' in 'demo_udfs';
(0 rows modified)

!update

# UDFs validate against real data (opaque placeholders return null at JDBC layer)
select greet("FIRST_NAME") as greeting from profile.members;

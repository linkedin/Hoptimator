!set outputformat mysql
!use k8s

create database "mydb" WITH (url 'jdbc:mysql://localhost:3306/mydb', driver 'com.mysql.cj.jdbc.Driver', schema 'myschema', dialect 'MySQL');
apiVersion: hoptimator.linkedin.com/v1alpha1
kind: Database
metadata:
  name: mydb
spec:
  dialect: MySQL
  driver: com.mysql.cj.jdbc.Driver
  schema: myschema
  url: jdbc:mysql://localhost:3306/mydb
!specify mydb

!set outputformat mysql
!use k8s

# ─────────────────────────────────────────────────────────────────────────────
# LogicalTable with nearline + online tiers (no offline). The implicit
# nearline-to-online pipeline lives inside the LT subgraph; the tier
# externals nest in their respective tier subgraphs.
# ─────────────────────────────────────────────────────────────────────────────

create or replace table "LOGICAL"."testevent-graph" ("KEY" varchar, "memberId" bigint, "pageKey" varchar);
(0 rows modified)

!update

flowchart TD
  subgraph n0["LogicalTable logical-testevent-graph"]
    direction LR
    subgraph s_nearline["nearline"]
      n2[("KAFKA.testevent-graph")]
    end
    subgraph s_online["online"]
      n3[("VENICE.testevent-graph")]
    end
    n1[/"logical-testevent-graph-nearline-to-online<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  end
  n2 --> n1
  n1 --> n3
!graph LOGICAL.testevent-graph

flowchart LR
  n0[("KAFKA.testevent-graph")]
  n1[/"logical-testevent-graph-nearline-to-online<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("VENICE.testevent-graph")]
  n0 --> n1
  n1 --> n2
!graph KAFKA.testevent-graph

flowchart LR
  n0[("VENICE.testevent-graph")]
  n1[/"logical-testevent-graph-nearline-to-online<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("KAFKA.testevent-graph")]
  n2 --> n1
  n1 --> n0
!graph VENICE.testevent-graph

# ─────────────────────────────────────────────────────────────────────────────
# LogicalTable with an offline tier + auto-spawned backfill trigger
# (Shape B: source = offline, sink = nearline; reverse-ETL pattern).
# The trigger renders inside the LT wrapper with dotted edges connecting
# its source and sink. Tier subgraphs nest by declaration order.
# ─────────────────────────────────────────────────────────────────────────────

create or replace table "LOGICAL-OFFLINE"."MEMBERS" ("ID" bigint, "NAME" varchar);
(0 rows modified)

!update

flowchart TD
  subgraph n0["LogicalTable logical-offline-members"]
    direction LR
    subgraph s_nearline["nearline"]
      n2[("ADS.MEMBERS")]
    end
    subgraph s_offline["offline"]
      n3[("ADS_CATALOG.ADS.MEMBERS")]
    end
    n1[/"logical-members-nearline-to-offline<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
    n4{"logical-members-offline-trigger<br/>(paused)"}
  end
  n2 --> n1
  n1 --> n3
  n3 -.-> n4
!graph LOGICAL-OFFLINE.MEMBERS

flowchart LR
  n0[("ADS_CATALOG.ADS.MEMBERS")]
  n1[/"logical-members-nearline-to-offline<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("ADS.MEMBERS")]
  n3{"logical-members-offline-trigger<br/>(paused)"}
  n2 --> n1
  n1 --> n0
  n0 -.-> n3
!graph ADS_CATALOG.ADS.MEMBERS

flowchart LR
  n0[("ADS.MEMBERS")]
  n1[/"logical-members-nearline-to-offline<br/>kind: FlinkSessionJob<br/>engine: Flink"/]
  n2[("ADS_CATALOG.ADS.MEMBERS")]
  n3{"logical-members-offline-trigger<br/>(paused)"}
  n0 --> n1
  n1 --> n2
  n2 -.-> n3
!graph ADS.MEMBERS

drop table "LOGICAL"."testevent-graph";
(0 rows modified)

!update

drop table "LOGICAL-OFFLINE"."MEMBERS";
(0 rows modified)

!update

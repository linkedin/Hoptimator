# ─────────────────────────────────────────────────────────────────────────────
# Test 6: CREATE OR REPLACE TABLE — update schema (no key)
# Should fail Venice validation - schema remains unchanged
# ─────────────────────────────────────────────────────────────────────────────
create or replace table "LOGICAL"."testevent" ("memberId" bigint, "pageKey" varchar, "sessionId" varchar NOT NULL);
Failed to generate key schema for Venice store testevent
!error


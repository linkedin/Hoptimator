| NAME                                 |
+--------------------------------------+
| logical-testevent-nearline-to-online |
+--------------------------------------+
(1 row)

!ok

select element_name from "k8s".pipeline_element_map where pipeline_name = 'logical-testevent-nearline-to-online' order by element_name;
